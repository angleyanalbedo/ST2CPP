FUNCTION TRUNC_REAL:REAL

	VAR_INPUT
		IN :	REAL;
	END_VAR


	TRUNC_REAL := UDINT_TO_REAL(DINT_TO_UDINT(TRUNC(IN)));
END_FUNCTION

FUNCTION RANGE_TO_BYTE:BYTE

	VAR_INPUT
		X :	REAL;
		LOW :	REAL;
		HIGH :	REAL;
	END_VAR

	Range_to_Byte := REAL_TO_BYTE(TRUNC_REAL((LIMIT(low,X,high)-low) * 255.0 / (high - low)));

END_FUNCTION