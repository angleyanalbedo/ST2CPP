FUNCTION TRUNC_REAL:REAL

	VAR_INPUT
		IN :	REAL;
	END_VAR


	TRUNC_REAL := UDINT_TO_REAL(DINT_TO_UDINT(TRUNC(IN)));
END_FUNCTION

FUNCTION RANGE_TO_WORD:WORD

	VAR_INPUT
		X :	REAL;
		LOW :	REAL;
		HIGH :	REAL;
	END_VAR

	Range_to_Word := REAL_TO_WORD(TRUNC_REAL((LIMIT(low,X,high)-low) * 65535.0 / (high - low)));

END_FUNCTION