FUNCTION _REAL_TO_UDINT:UDINT

  	VAR_INPUT
		X :	REAL;
	END_VAR

	IF REAL_TO_UDINT(0.5) = UDINT#1 THEN
		_REAL_TO_UDINT := REAL_TO_UDINT(x);
	ELSIF X > 0.0 THEN
		_REAL_TO_UDINT := REAL_TO_UDINT(x+0.5); 
	ELSIF X < 0.0 THEN 
		_REAL_TO_UDINT := REAL_TO_UDINT(x-0.5); 
	ELSE 
		_REAL_TO_UDINT := UDINT#0;
	END_IF;

END_FUNCTION

FUNCTION MINUTE_TO_TIME:TIME

	VAR_INPUT
		IN :	REAL;
	END_VAR

	minute_to_time := UDINT_TO_TIME(_REAL_TO_UDINT(IN * 60000.0));

END_FUNCTION