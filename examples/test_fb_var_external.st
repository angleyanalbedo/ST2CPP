FUNCTION_BLOCK MY_FB
  VAR_INPUT
    X : INT;
  END_VAR
  VAR_OUTPUT
    Y : INT;
  END_VAR
  VAR_EXTERNAL
    GLOBAL_COUNTER : INT;
  END_VAR
  Y := X + GLOBAL_COUNTER;
  GLOBAL_COUNTER := GLOBAL_COUNTER + 1;
END_FUNCTION_BLOCK

PROGRAM MAIN
  VAR
    GLOBAL_COUNTER : INT := 100;
    FB_INST : MY_FB;
    RESULT : INT;
  END_VAR
  FB_INST(X := 10);
  RESULT := FB_INST.Y;
END_PROGRAM
