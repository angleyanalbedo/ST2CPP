{
  "name": "st2c",
  "displayName": "ST2C — IEC 61131-3 ST Language",
  "description": "ST language support: syntax highlight, hover, completion, diagnostics, compile, and GDB debug",
  "version": "1.0.0",
  "publisher": "st2c",
  "private": true,
  "license": "GPL-2.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Linters"],
  "activationEvents": [
    "onLanguage:st",
    "onCommand:st2c.compileCurrent",
    "onCommand:st2c.compileProject",
    "onCommand:st2c.debugRuntime",
    "onDebugInitialConfigurations"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "st",
        "aliases": ["Structured Text", "ST", "IEC 61131-3"],
        "extensions": [".st"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "st",
        "scopeName": "source.st",
        "path": "./syntaxes/st.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "st2c.compileCurrent",
        "title": "ST2C: Compile Current File → Build Runtime",
        "icon": "$(gear)"
      },
      {
        "command": "st2c.compileProject",
        "title": "ST2C: Compile All ST Files → Build Runtime",
        "icon": "$(tools)"
      },
      {
        "command": "st2c.debugRuntime",
        "title": "ST2C: Debug Current File (Compile + Build + Launch GDB)",
        "icon": "$(debug-alt)"
      },
      {
        "command": "st2c.getDebugAdapterExecutable",
        "title": "Internal: Return debug adapter path",
        "icon": "$(debug)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "st2c.debugRuntime",
          "when": "editorLangId == st",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "st2c.compileCurrent",
        "key": "ctrl+shift+b",
        "when": "editorLangId == st"
      }
    ],
    "debuggers": [
      {
        "type": "st2c",
        "label": "ST2C Debug",
        "languages": ["st"],
        "adapterExecutableCommand": "st2c.getDebugAdapterExecutable",
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the debug runtime executable"
              },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Command-line arguments"
              },
              "miDebuggerPath": {
                "type": "string",
                "description": "Path to GDB executable",
                "default": "gdb.exe"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "st2c",
            "request": "launch",
            "name": "ST2C: Debug PLC Runtime",
            "program": "${workspaceFolder}/target/desktop/build/plc_runtime_desktop_dbg.exe",
            "args": ["--cycle-us", "1000"],
            "cwd": "${workspaceFolder}"
          }
        ]
      }
    ],
    "configuration": {
      "title": "ST2C",
      "properties": {
        "st2c.jarPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to st2c-jar-with-dependencies.jar. If empty, uses `../../java/target/st2c-jar-with-dependencies.jar` relative to the extension directory."
        },
        "st2c.outputDir": {
          "type": "string",
          "default": "${workspaceFolder}/output/flat/build",
          "markdownDescription": "Output directory for generated C++ files."
        },
        "st2c.makeTarget": {
          "type": "string",
          "default": "desktop",
          "enum": ["desktop", "windows"],
          "markdownDescription": "Runtime target to build: `desktop` or `windows`."
        },
        "st2c.makePath": {
          "type": "string",
          "default": "mingw32-make",
          "markdownDescription": "Path to `make` executable. Default: `mingw32-make`."
        },
        "st2c.gdbPath": {
          "type": "string",
          "default": "gdb.exe",
          "markdownDescription": "Path to GDB executable used for debugging."
        },
        "st2c.stdlibPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to custom IEC stdlib .st file. If empty, uses built-in stdlib from classpath."
        },
        "st2c.pythonPath": {
          "type": "string",
          "default": "python",
          "markdownDescription": "Path to Python interpreter used for config generation (gen_config.py). Default: `python`."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
