{
  "comments": {
    "lineComment": "//",
    "blockComment": ["(*", "*)"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(PROGRAM|FUNCTION|FUNCTION_BLOCK|VAR|TYPE|STRUCT|IF|FOR|WHILE|REPEAT|CASE)\\b",
      "end": "^\\s*(END_PROGRAM|END_FUNCTION|END_FUNCTION_BLOCK|END_VAR|END_TYPE|END_STRUCT|END_IF|END_FOR|END_WHILE|END_REPEAT|END_CASE)\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(PROGRAM|FUNCTION|FUNCTION_BLOCK|VAR|VAR_INPUT|VAR_OUTPUT|VAR_IN_OUT|VAR_TEMP|VAR_GLOBAL|VAR_EXTERNAL|TYPE|STRUCT|IF|FOR|WHILE|REPEAT|CASE)\\b.*$",
    "decreaseIndentPattern": "^\\s*(END_PROGRAM|END_FUNCTION|END_FUNCTION_BLOCK|END_VAR|END_TYPE|END_STRUCT|END_IF|END_FOR|END_WHILE|END_REPEAT|END_CASE|ELSE|ELSIF)\\b.*$"
  }
}
